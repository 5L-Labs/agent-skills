# SECURITY: this file contains WSJ session tokens with full account access.
# .env is gitignored, but the skill directory is git-tracked — never `git add .env`.
#
# Copy to .env and paste your entire WSJ browser Cookie header. WSJ's session is
# split across many cookies (DJSESSION, djcs_*, Adobe AMCV_*, datadome, consent
# flags, ...) and the full Cookie header is required — no minimal subset works.
#
# How to capture:
#   1) Sign in to https://www.wsj.com.
#   2) DevTools -> Network -> click any www.wsj.com request -> Request Headers
#      -> find "Cookie:" -> copy the entire value.
#   3) Or: while on a wsj.com page, run the bookmarklet from README.md and pipe
#      to scripts/set_cookie.py.
#
# When the skill prints SESSION_EXPIRED, re-paste.

WSJ_COOKIE=paste-the-entire-Cookie-header-value-from-your-browser-here

# Optional tuning
# WSJ_CACHE_DIR=/absolute/path/to/cache   # default: <skill_dir>/cache
# WSJ_REQUEST_SPACING_MS=400              # delay between origin fetches (WSJ is sensitive)
# WSJ_MAX_FETCHES=200                     # per-invocation safety cap
# WSJ_USER_AGENT=                         # override the default UA
